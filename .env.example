# LLM provider: "google" (default), "anthropic", or "zai"
LLM_PROVIDER=google

# Provider keys
GOOGLE_API_KEY=...
# ANTHROPIC_API_KEY=sk-ant-...
# ZAI_API_KEY=...           # z.ai (Zhipu) — unlimited glm-4.7-flash, great for dodging rate limits

# Model + fallback chain (rolled to on transient 429s). Per-model rpm/tpm:
#   gemini-3.1-flash-lite  15rpm/250k   (default)
#   gemini-3-flash-preview  5rpm/250k
#   gemma-4-31b-it         15rpm/unlimited
GOOGLE_MODEL=gemini-3.1-flash-lite
GOOGLE_MODEL_FALLBACKS=gemini-3-flash-preview,gemma-4-31b-it
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MODEL_FALLBACKS=claude-haiku-4-5-20251001

# z.ai (set LLM_PROVIDER=zai to use). glm-4.7-flash is unlimited; "thinking" is
# auto-disabled for glm-4.5+ so JSON responses aren't truncated.
# ZAI_MODEL=glm-4.7-flash
# ZAI_MODEL_FALLBACKS=
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# Hosted preview controls (leave unset for local single-user dev)
# HAI_ACCESS_CODE=          # shared passphrase gating the preview
HAI_DAILY_CALL_CAP=80       # per-user/day LLM-call cap (0 = unlimited)
